{
  "name": "poc-node-cluster",
  "version": "1.0.0",
  "private": true,
  "description": "PoC simples para validar MySQL Cluster com Sequelize e Knex.",
  "main": "src/sequelize-check.js",
  "scripts": {
    "db:prepare": "node ./src/prepare-database.js",
    "migrate": "knex --knexfile knexfile.cjs migrate:latest",
    "sequelize:check": "node ./src/sequelize-check.js",
    "verify": "node ./src/verify-ndb-table.js",
    "test:all": "node ./src/run-all.js"
  },
  "dependencies": {
    "knex": "^3.1.0",
    "mysql2": "^3.15.2",
    "sequelize": "^6.37.7"
  }
}
